{
  "name": "markdown-reader",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:vite": "vite build --watch",
    "dev:electron": "wait-on -i 200 dist/index.html && electron .",
    "dev": "yarn build:electron && concurrently -k \"yarn dev:vite\" \"yarn dev:electron\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/postbuild-electron.mjs",
    "build": "tsc -b && yarn build:renderer && yarn build:electron",
    "start": "electron .",
    "lint": "eslint .",
    "preview": "vite preview",
    "pack": "npm run build && electron-builder",
    "postinstall": "node node_modules/electron/install.js"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@types/highlight.js": "^10.1.0",
    "antd": "^5.25.3",
    "autoprefixer": "^10.4.21",
    "highlight.js": "^11.11.1",
    "html-to-docx": "^1.8.0",
    "katex": "^0.16.22",
    "mermaid": "^11.16.0",
    "postcss": "^8.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.MDScape.reader",
    "productName": "Markdown 预览 + 打印 + 导出",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
